# =============================================
# Fashion Data Engine - 환경 설정
# =============================================

# 데이터베이스
# 로컬 개발: SQLite (기본값, 별도 설치 불필요)
DATABASE_URL=sqlite+aiosqlite:///./data/fashion.db

# PostgreSQL 사용 시 아래 주석 해제:
# DATABASE_URL=postgresql+asyncpg://fashion:password@localhost:5432/fashion_db

# 크롤러 설정
CRAWLER_DELAY_SECONDS=2.0        # 요청 간 대기 시간 (크롤링 부하 방지)
CRAWLER_MAX_RETRIES=3
CRAWLER_TIMEOUT_SECONDS=30
CRAWLER_HEADLESS=true            # false로 하면 브라우저 창이 열림
TZ=Asia/Seoul

# API 설정
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
ADMIN_BEARER_TOKEN=replace-with-strong-random-token
GPT_ACTIONS_API_KEY=replace-with-strong-random-token
MCP_API_KEY=replace-with-strong-random-token
REDIS_URL=
INTERNAL_API_BASE_URL=http://127.0.0.1:8000
INTERNAL_API_KEY=replace-with-strong-random-token
CORS_ALLOWED_ORIGINS=http://localhost:3000
# 배포 시 예시:
# CORS_ALLOWED_ORIGINS=https://fashion-data-engine.vercel.app,https://www.your-domain.com

# OpenAI (GPT fallback parser / channel discovery)
OPENAI_API_KEY=
SEMANTIC_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# Discord 알림 (Phase 4 — 세일·신제품·가격하락 알림)
# Discord 서버 설정 → 채널 편집 → 연동 → 웹후크 → URL 복사
DISCORD_WEBHOOK_URL=
# Intel Hub Discord 알림 (intel 전용 채널)
INTEL_DISCORD_WEBHOOK_URL=

# 알림 트리거 임계값 (기본 10% = 0.10)
ALERT_PRICE_DROP_THRESHOLD=0.10

# Intel Hub (Sprint 0)
INTEL_INGEST_ENABLED=false
INTEL_DEFAULT_TIME_RANGE_DAYS=7
NEXT_PUBLIC_MAP_STYLE_URL=https://demotiles.maplibre.org/style.json
NEXT_PUBLIC_INTEL_DEFAULT_LAYER_SET=drops,collabs,news,sale_start

# Web Push
PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_PRIVATE_KEY=
PUSH_VAPID_SUBJECT=mailto:admin@example.com
